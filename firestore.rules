rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ─────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // True if the calling user's UID is in the circle's joinedUsers array
    function isCircleMember(circleId) {
      return isAuthenticated() &&
        request.auth.uid in
          get(/databases/$(database)/documents/bookCircles/$(circleId)).data.joinedUsers;
    }

    // ─── Books ────────────────────────────────────────────────────────────────
    match /books/{bookId} {
      allow read: if true;
      allow create: if isAuthenticated() &&
        request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.ownerId) || isAdmin();
    }

    // ─── Exchange Requests ────────────────────────────────────────────────────
    match /exchangeRequests/{requestId} {
      allow read: if isOwner(resource.data.requesterId) ||
                     isOwner(resource.data.ownerId) || isAdmin();
      allow create: if isAuthenticated() &&
        request.resource.data.requesterId == request.auth.uid &&
        request.resource.data.requesterId != request.resource.data.ownerId;
      allow update: if isOwner(resource.data.requesterId) ||
                       isOwner(resource.data.ownerId) || isAdmin();
      allow delete: if isOwner(resource.data.requesterId) || isAdmin();
    }

    // ─── Direct Chats ─────────────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read, update: if isAuthenticated() &&
        request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() &&
        request.auth.uid in request.resource.data.participants;
    }

    // ─── Direct Messages ──────────────────────────────────────────────────────
    match /messages/{messageId} {
      allow read: if isAuthenticated() && (
        isOwner(resource.data.senderId) ||
        isOwner(resource.data.receiverId)
      ) || isAdmin();
      allow create: if isOwner(request.resource.data.senderId);
      allow update: if isOwner(resource.data.receiverId);
    }

    // ─── Notifications ────────────────────────────────────────────────────────
    match /notifications/{notificationId} {
      allow read, update, delete: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated();
    }

    // ─── Users ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin();
    }

    // ─── Warnings ─────────────────────────────────────────────────────────────
    match /warnings/{warningId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // ─── Book Circles ─────────────────────────────────────────────────────────
    match /bookCircles/{circleId} {
      // Circle metadata is public (name, description, member count shown on browse page)
      allow read: if true;

      // Any authenticated user may create a circle; creator must be themselves
      allow create: if isAuthenticated() &&
        request.resource.data.creatorId == request.auth.uid &&
        request.resource.data.keys().hasAll(['name', 'creatorId', 'joinedUsers', 'membersCount']);

      // Joins/leaves: only joinedUsers and membersCount may change.
      // Admins may update any field.
      allow update: if isAdmin() || (
        isAuthenticated() &&
        request.resource.data.diff(resource.data)
          .affectedKeys().hasOnly(['joinedUsers', 'membersCount'])
      );

      // Only the creator or an admin can delete a circle
      allow delete: if isOwner(resource.data.creatorId) || isAdmin();

      // ── Discussions ── members-only read/write ─────────────────────────────
      match /discussions/{postId} {
        allow read: if isCircleMember(circleId);

        allow create: if isCircleMember(circleId) &&
          request.resource.data.authorId == request.auth.uid &&
          request.resource.data.keys().hasAll(['text', 'authorId', 'authorName', 'createdAt']);

        // Author can edit their post; any member can like (only likes/likedBy change)
        allow update: if isAdmin() || (
          isCircleMember(circleId) && (
            isOwner(resource.data.authorId) ||
            request.resource.data.diff(resource.data)
              .affectedKeys().hasOnly(['likedBy', 'likes'])
          )
        );

        allow delete: if isOwner(resource.data.authorId) || isAdmin();
      }
    }

    // ─── Circle Group Chat ────────────────────────────────────────────────────
    match /circleChats/{circleId}/messages/{messageId} {
      // Only members can read or write messages
      allow read: if isCircleMember(circleId);

      allow create: if isCircleMember(circleId) &&
        request.resource.data.senderId == request.auth.uid &&
        request.resource.data.keys().hasAll(['senderId', 'senderName', 'text', 'createdAt']);

      // Messages are immutable; only admins can delete
      allow update, delete: if isAdmin();
    }

    // ─── Circle Books ─────────────────────────────────────────────────────────
    match /circleBooks/{circleId}/books/{bookId} {
      // Only members can view books shared in a circle
      allow read: if isCircleMember(circleId);

      allow create: if isCircleMember(circleId) &&
        request.resource.data.sharedById == request.auth.uid &&
        request.resource.data.keys().hasAll(['title', 'sharedById', 'sharedByName', 'circleId', 'createdAt']);

      allow update: if isOwner(resource.data.sharedById) || isAdmin();
      allow delete: if isOwner(resource.data.sharedById) || isAdmin();
    }
  }
}
