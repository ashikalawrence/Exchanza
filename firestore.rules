rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Books Collection
    match /books/{bookId} {
      // Anyone can read public books
      allow read: if true;
      // Only authenticated users can create
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      // Only the owner can edit or delete their book
      allow update, delete: if isOwner(resource.data.ownerId);
    }

    // Exchange Requests Collection
    match /exchangeRequests/{requestId} {
      // Users can read requests they made or received
      allow read: if isOwner(resource.data.requesterId) || isOwner(resource.data.ownerId);
      // Auth users can create a request
      allow create: if isAuthenticated() && request.resource.data.requesterId == request.auth.uid;
      // Only the book owner or requester can update
      allow update: if isOwner(resource.data.requesterId) || isOwner(resource.data.ownerId);
      // Requester can delete
      allow delete: if isOwner(resource.data.requesterId);
    }

    // Chats Collection
    match /chats/{chatId} {
      // Users can only read and write chats they are a participant of
      allow read, update: if isAuthenticated() && request.auth.uid in resource.data.participants;
      // Users can create a chat if they are a participant
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
    }

    // Messages Collection
    match /messages/{messageId} {
      // Users can only read messages where they are the sender or receiver
      allow read: if isOwner(resource.data.senderId) || isOwner(resource.data.receiverId);
      // Users can create a message if they are the sender
      allow create: if isOwner(request.resource.data.senderId);
      // Receiver can update read status
      allow update: if isOwner(resource.data.receiverId);
    }

    // Notifications Collection
    match /notifications/{notificationId} {
      // Users can only read and update their own notifications
      allow read, update, delete: if isOwner(resource.data.userId);
      // Auth users can create notifications for others
      allow create: if isAuthenticated();
    }

    // Users Collection
    match /users/{userId} {
      // Anyone can read public profiles
      allow read: if true;
      // Users can only edit their own profile
      allow write: if isOwner(userId);
    }

    // Book Circles Collection
    match /bookCircles/{circleId} {
      // Anyone can read circles
      allow read: if true;
      // Auth users can create
      allow create: if isAuthenticated();
      // Any member can update
      allow update: if isAuthenticated();
      
      // Circle discussions
      match /discussions/{messageId} {
        allow read: if true;
        allow create: if isAuthenticated();
        allow update, delete: if isOwner(resource.data.senderId);
      }
    }
  }
}
